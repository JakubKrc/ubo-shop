# Copy to .env and fill in. Never commit .env.

# MariaDB (read by the mariadb:11 image directly)
MYSQL_ROOT_PASSWORD=replace_with_strong_random
MYSQL_DATABASE=prestashop
MYSQL_USER=prestashop
MYSQL_PASSWORD=replace_with_strong_random

# PrestaShop — database connection
DB_SERVER=shop-db
DB_NAME=prestashop
DB_USER=prestashop
DB_PASSWD=replace_with_same_as_MYSQL_PASSWORD
DB_PREFIX=ps_

# PrestaShop — initial install (runs only on first boot)
PS_INSTALL_AUTO=1
PS_DOMAIN=shop.ubo.jkjdev.eu
PS_ENABLE_SSL=1
PS_COUNTRY=us
PS_LANGUAGE=en
ADMIN_MAIL=admin@jkjdev.eu
ADMIN_PASSWD=replace_with_strong_random
